# tn-portal Environment Variables
# Copy this file to .env.local and configure for your local environment
# DO NOT commit .env.local to version control!

# ===================================
# API Configuration (Public - exposed to browser)
# ===================================

# API Base URL
PUBLIC_API_BASE_URL=http://localhost:8080

# API Request Timeout (milliseconds)
PUBLIC_API_TIMEOUT=30000

# ===================================
# Azure AD Authentication (Public - exposed to browser)
# ===================================

# Azure AD Application (client) ID
PUBLIC_SSO_CLIENT_ID=your-client-id-here

# Azure AD Directory (tenant) ID
PUBLIC_SSO_TENANT_ID=your-tenant-id-here

# Custom API scope name (not the full api:// URL)
PUBLIC_SSO_CUSTOM_SCOPE=read.user
# tn-portal Environment Variables
# Copy this file to .env.local and configure for your local environment
# DO NOT commit .env.local to version control!

# ===================================
# API Configuration (Public - exposed to browser)
# ===================================

# API Base URL
PUBLIC_API_BASE_URL=http://localhost:8080

# API Request Timeout (milliseconds)
PUBLIC_API_TIMEOUT=

PUBLIC_SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
PUBLIC_SSO_TENANT_ID=
PUBLIC_SSO_CUSTOM_SCOPE=User.Read
PUBLIC_SSO_REDIRECT_URI=
PUBLIC_TN_PORTAL_BASE_PATH=/tn-portal